# Database
POSTGRES_DB=fireacademy
POSTGRES_USER=fireacademy
POSTGRES_PASSWORD=CHANGE_TO_STRONG_PASSWORD

# Mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# OAuth2 - Google (optional - uncomment to enable)
# OAUTH2_GOOGLE_CLIENT_ID=your_google_client_id
# OAUTH2_GOOGLE_CLIENT_SECRET=your_google_client_secret

# Admin
ADMIN_EMAIL=admin@example.com

# JWT
JWT_SECRET=CHANGE_TO_RANDOM_KEY_MIN_32_CHARS

# GHCR (GitHub Container Registry)
GHCR_OWNER=nextstepprodev

# Deployment
VERSION=latest

# Application
CORS_ORIGINS=https://fireworkout.pl,https://www.fireworkout.pl
APP_BASE_URL=https://fireworkout.pl
SITE_URL=https://fireworkout.pl
